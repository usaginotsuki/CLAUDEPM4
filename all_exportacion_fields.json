    {
        "id":  3,
        "name":  "frm_exportacion_porcentaje_formateado",
        "type":  "javascript",
        "order":  3,
        "byPass":  false,
        "formula":  "const raw = this.frm_exportacion_porcentaje;\r\n  if (raw == null || raw === \"\") return \"\";\r\n\r\n  let s = String(raw).trim().replace(/\\s/g, \"\").replace(/%/g, \"\");\r\n\r\n  s = s.replace(\",\", \".\");\r\n\r\n  s = s.replace(/[^0-9.-]/g, \"\");\r\n\r\n  const n = Number(s);\r\n  if (!Number.isFinite(n)) return \"\";\r\n\r\n  return `${n} %`;",
        "property":  "frm_exportacion_porcentaje_formateado"
    },
    {
        "id":  8,
        "name":  "frm_exportacion_ventas_formateado",
        "type":  "javascript",
        "order":  8,
        "byPass":  false,
        "formula":  "const raw = this.frm_exportacion_ventas;\r\n  if (raw == null || raw === \"\") return \"\";\r\n\r\n  let s = String(raw).trim().replace(/\\s/g, \"\").replace(/\\$/g, \"\");\r\n\r\n  if (s.includes(\".\")) {\r\n    s = s.split(\".\")[0];\r\n  } else {\r\n    if (/,(\\d{1,6})$/.test(s)) {\r\n      s = s.replace(/,(\\d{1,6})$/, \"\");\r\n    }\r\n  }\r\n\r\n  s = s.replace(/[^\\d-]/g, \"\");\r\n  if (!s || s === \"-\") return \"\";\r\n\r\n  const negative = s.startsWith(\"-\");\r\n  const digits = negative ? s.slice(1) : s;\r\n\r\n  const formatted = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \".\");\r\n  return negative ? `-${formatted}` : formatted;",
        "property":  "frm_exportacion_ventas_formateado"
    }
]
