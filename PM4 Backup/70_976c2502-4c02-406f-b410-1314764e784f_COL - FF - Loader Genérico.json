o absoluto (solo para probar) *\/ html, body, :where(*) { font-family:'ZurichSans' !important; }\r\n\r\n\r\n\/* Fondo blanco semitransparente que cubre toda la pantalla *\/\r\n#global-loader-overlay {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100vw;\r\n  height: 100vh;\r\n  background: rgba(255, 255, 255, 0.75);\r\n  z-index: 9999;\r\n  display: none;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n\/* Mostrar el loader *\/\r\n#global-loader-overlay.show {\r\n  display: flex;\r\n}\r\n\r\n\/* Spinner circular con color corporativo *\/\r\n#global-loader-spinner {\r\n  width: 60px;\r\n  height: 60px;\r\n  border: 6px solid #e0e0e0;\r\n  border-top: 6px solid #2167AE;\r\n  border-radius: 50%;\r\n  animation: spin 1s linear infinite;\r\n}\r\n\r\n\/* Animaci\u00f3n *\/\r\n@keyframes spin {\r\n  0% { transform: rotate(0deg); }\r\n  100% { transform: rotate(360deg); }\r\n}","created_at":"2021-04-22T09:49:10-04:00","updated_at":"2025-12-09T21:33:06-05:00","status":"ACTIVE","key":"interstitial","watchers":[],"translations":null,"is_template":0,"asset_type":null,"is_default":0,"projects":"[{\"id\":1,\"uuid\":\"9fe6abf3-eeb2-4ed6-90a3-8b20285657ed\",\"user_id\":3,\"title\":\"CIMMR - COL - Fast Flow\",\"status\":\"ACTIVE\",\"deleted_at\":null,\"created_at\":\"2025-09-17T13:39:21-04:00\",\"updated_at\":\"2026-04-29T19:25:15-04:00\"}]","categories":[{"id":7,"uuid":"9f75e658-3ff6-4387-b05d-2a4a133babb2","name":"Fast Flow - Zurich","status":"ACTIVE","is_system":0,"created_at":"2025-07-23T16:14:05-04:00","updated_at":"2025-07-23T16:14:05-04:00","pivot":{"category_type":"ProcessMaker\\Models\\ScreenCategory","assignable_id":70,"category_id":7}}]}],"screen_categories":[],"scripts":[]}